rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Deny all client access to the mail collection.
    // The Firebase Trigger Email extension (Admin SDK) bypasses these rules,
    // so Cloud Functions can still write here. This prevents authenticated
    // users from sending spam via the app's SMTP account.
    match /mail/{document} {
      allow read, write: if false;
    }

    // app_errors: any authenticated user can write (errors logged by the app);
    // only the admin can read (via the Error Log admin tab).
    match /app_errors/{document} {
      allow write: if true;
      allow read: if request.auth != null && request.auth.uid == 'WUhNUBzjE7TVpU2PgV6ATjsXk9J2';
    }

    // admin_config: admin-only. Cloud Functions use the Admin SDK and bypass
    // these rules; this prevents regular users from reading or modifying
    // alert configuration.
    match /admin_config/{document} {
      allow read, write: if request.auth != null && request.auth.uid == 'WUhNUBzjE7TVpU2PgV6ATjsXk9J2';
    }

    match /{document=**} {
      allow read, write, delete: if request.auth != null;
    }
  }
}