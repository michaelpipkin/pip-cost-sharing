{
  "name": "pipsplit",
  "version": "1.21.20",
  "type": "module",
  "scripts": {
    "reset-packages": "rm -rf node_modules && rm -rf pnpm-lock.yaml && pnpm install",
    "ng": "ng",
    "start": "ng serve --host=local.dev.com",
    "start:ci": "ng serve --host=local.dev.com --configuration=ci",
    "kill-ports": "pnpx kill-port 4000 && pnpx kill-port 4500 && pnpx kill-port 5000 && pnpx kill-port 8080 && pnpx kill-port 9099 && pnpx kill-port 9150 && pnpx kill-port 9199",
    "emu": "firebase emulators:start",
    "emu:data": "firebase emulators:start --import seed-data",
    "emu:export": "firebase emulators:export seed-data --force",
    "get-indexes": "firebase firestore:indexes",
    "sync-indexes": "node ./updateFirestoreIndexes.js",
    "build:cap": "ng build --configuration=production && npx cap sync",
    "build:prod": "pnpm --no-git-tag-version version patch && node ./setBuildDate.js && node ./updatePrivacyDate.js && ng build --configuration=production && node ./generate-sitemap.js",
    "build:ci": "node ./setBuildDate.js && node ./updatePrivacyDate.js && ng build --configuration=production && node ./generate-sitemap.js",
    "update-angular": "ng update @angular/cli @angular/core @angular/material @angular/cdk",
    "e2e:report": "playwright show-report",
    "e2e:install": "playwright install",
    "e2e:ci": "cross-env CI=true playwright test",
    "e2e:ci:headed": "cross-env CI=true playwright test --headed",
    "e2e:ci:fast": "cross-env CI=true playwright test navigation.spec.ts auth-unauthenticated.spec.ts auth-authenticated.spec.ts --project=chromium",
    "e2e:local": "playwright test",
    "e2e:local:debug": "playwright test --debug",
    "e2e:local:ui": "playwright test --ui",
    "e2e:local:headed": "playwright test --headed",
    "e2e:local:fast": "playwright test navigation.spec.ts auth-unauthenticated.spec.ts auth-authenticated.spec.ts --project=chromium",
    "e2e:local:fast:headed": "playwright test navigation.spec.ts auth-unauthenticated.spec.ts auth-authenticated.spec.ts --project=chromium --headed",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "query": "pnpm --dir scripts/db query",
    "deps:dry-run": "dependabot-agent --dry-run",
    "deps:fix": "dependabot-agent"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^22.0.2",
    "@angular/common": "^22.0.2",
    "@angular/compiler": "^22.0.2",
    "@angular/core": "^22.0.2",
    "@angular/forms": "^22.0.2",
    "@angular/material": "^22.0.2",
    "@angular/platform-browser": "^22.0.2",
    "@angular/platform-server": "^22.0.2",
    "@angular/router": "^22.0.2",
    "@angular/ssr": "^22.0.3",
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor-firebase/analytics": "^8.3.0",
    "@capacitor-firebase/authentication": "^8.3.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/text-zoom": "^8.0.1",
    "@capawesome/capacitor-android-edge-to-edge-support": "^8.0.8",
    "@ngrx/signals": "^21.1.1",
    "@ngx-translate/core": "^18.0.0",
    "@ngx-translate/http-loader": "^18.0.0",
    "bootstrap": "^5.3.8",
    "firebase": "^12.15.0",
    "moment": "^2.30.1",
    "replace-in-file": "^8.4.0",
    "shepherd.js": "^15.2.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.3",
    "@angular/cli": "^22.0.3",
    "@angular/compiler-cli": "^22.0.2",
    "@capacitor/assets": "^3.0.5",
    "@hcaptcha/types": "^1.2.0",
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "dependabot-agent": "^0.1.2",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "prettier-eslint-cli": "^9.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.62.2",
    "@rollup/rollup-win32-x64-msvc": "^4.62.2"
  }
}
